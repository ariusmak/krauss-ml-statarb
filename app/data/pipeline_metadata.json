    "MT-DNN": {
      "type": "Multi-task DNN with shared trunk + cls and reg heads",
      "source": "src/krauss/models/dnn_multitask.py:55-275",
      "hyperparameters": {
        "trunk": "31 -> Maxout(31) -> Maxout(10) -> Maxout(5)",
        "cls_head": "Linear(5, 1) + sigmoid",
        "reg_head": "Linear(5, 1)",
        "loss": "0.5 * BCE + 0.5 * Huber",
